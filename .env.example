# LLM / Embedding
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=your_openai_base_url_here

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Chroma 配置
# CHROMA_MODE: persistent | http | auto
CHROMA_MODE=persistent
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# SQLite 配置
FINGERPRINT_DB=data/fingerprints.sqlite

# Retrieval 配置
RETRIEVAL_MODE_DEFAULT=vector
HYBRID_TOP_K=20
RERANK_TOP_N=8
RERANK_ENABLED=true
RERANK_BACKEND=sentence_transformers
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=auto
BGE_RERANK_MODEL=BAAI/bge-reranker-v2-m3
BGE_RERANK_USE_FP16=false
RERANK_BLEND_ALPHA=0.85

# Agent App（独立运行）
RAG_API_BASE_URL=http://127.0.0.1:8000
RAG_REQUEST_TIMEOUT_SEC=30
AGENT_DEFAULT_TEAM_ID=team_test
AGENT_DEFAULT_TOP_K=5
AGENT_DEFAULT_RETRIEVAL_MODE=hybrid_rerank
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_TOP_K_DEFAULT=3
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_DEPTH=basic
